# Copy to .env.local and fill in. These are the ONLY env vars the Next app needs.
# The service_role key is NEVER used by the app — it lives only in the Edge
# Function (set via `supabase secrets set`), never here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-anon-or-publishable-key

# --- Blooio texting (SERVER-ONLY — never prefix with NEXT_PUBLIC_) ---
# Read by the Send-see-off Server Action. Must also be set on Railway.
BLOOIO_API_KEY=api_your-blooio-key
# Optional: override the API base (defaults to https://api.blooio.com)
# BLOOIO_API_BASE=https://api.blooio.com

# --- Edge Function secret (NOT read by the Next app) ---
# Set on Supabase, not here:
#   supabase secrets set WEBHOOK_SECRET=$(openssl rand -hex 32)
